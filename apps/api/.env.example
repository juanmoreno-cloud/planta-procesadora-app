# Plantilla de variables de entorno del backend.
# Copia este archivo como ".env" y rellena con tus propios valores de Supabase.
# (El .env real NO se sube a GitHub.)

# --- Base de datos PostgreSQL de Supabase (Prisma) ---
# OJO: si tu contraseña tiene caracteres especiales (! , @ # etc.) deben ir codificados
# en la URL (ej. "!" = %21, "," = %2C).
DATABASE_URL="postgresql://postgres.TU_REF:TU_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.TU_REF:TU_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase ---
SUPABASE_URL="https://TU_REF.supabase.co"
SUPABASE_ANON_KEY="tu-anon-key"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

PORT=3000
